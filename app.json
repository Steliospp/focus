{
  "expo": {
    "name": "Log Your Mind",
    "slug": "log-your-mind",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "logyourmind",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F0E8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.logyourmind.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Log Your Mind needs your microphone so you can record voice journal entries.",
        "NSCameraUsageDescription": "Log Your Mind needs camera access for proof photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F5F0E8"
      },
      "permissions": [
        "RECORD_AUDIO"
      ],
      "package": "com.logyourmind.app"
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": "Log Your Mind needs your microphone so you can record voice journal entries."
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      "@react-native-community/datetimepicker"
    ]
  }
}
